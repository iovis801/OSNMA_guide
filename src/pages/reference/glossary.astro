---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHeader from '@/components/ui/PageHeader.astro';
import { GLOSSARY } from '@/data/glossary';

const entries = [...GLOSSARY].sort((a, b) => a.term.localeCompare(b.term));
---
<BaseLayout title="Glossary" description="Every OSNMA acronym, defined.">
  <PageHeader eyebrow="7 · Reference" title="Glossary" lead="Every OSNMA acronym, defined." />

  <div class="not-prose">
    <input
      id="glossary-search"
      type="search"
      placeholder="Filter by acronym or word…"
      autocomplete="off"
      class="mb-5 w-full rounded-lg border border-line bg-panel px-4 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none"
    />

    <div id="glossary-list" class="grid gap-3 sm:grid-cols-2">
      {
        entries.map((e) => (
          <div
            class="glossary-item rounded-xl border border-line bg-panel/50 p-4"
            data-search={`${e.term} ${e.full} ${e.def}`.toLowerCase()}
          >
            <div class="flex items-baseline gap-2">
              <span class="font-mono text-base font-bold text-brand-bright">{e.term}</span>
              <span class="text-xs text-muted">{e.full}</span>
            </div>
            <p class="mt-1.5 text-sm text-ink/90">{e.def}</p>
          </div>
        ))
      }
    </div>

    <p id="glossary-empty" class="mt-6 hidden text-sm text-muted">No matching terms.</p>
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('glossary-search') as HTMLInputElement | null;
  const items = Array.from(document.querySelectorAll<HTMLElement>('.glossary-item'));
  const empty = document.getElementById('glossary-empty');

  input?.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    let visible = 0;
    for (const item of items) {
      const match = !q || (item.dataset.search ?? '').includes(q);
      item.classList.toggle('hidden', !match);
      if (match) visible += 1;
    }
    empty?.classList.toggle('hidden', visible !== 0);
  });
</script>
