---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { withBase } from '@/lib/withBase';
import PageHeader from '@/components/ui/PageHeader.astro';
import Callout from '@/components/ui/Callout.astro';

const topicMap: { topic: string; where: string }[] = [
  { topic: 'NMA Header (NMAS, CID, CPKS)', where: 'SIS ICD 3.1' },
  { topic: 'DSM-KROOT (signed root key)', where: 'SIS ICD 3.2.3' },
  { topic: 'DSM-PKR (public key renewal)', where: 'SIS ICD 3.2.2' },
  { topic: 'MACK message, tags, Tag-Info', where: 'SIS ICD 4' },
  { topic: 'Signed message M and verification inputs', where: 'SIS ICD 6.3' },
  { topic: 'TESLA key chain derivation', where: 'SIS ICD 6.4' },
  { topic: 'Merkle tree construction', where: 'SIS ICD 6.2' },
  { topic: 'MAC look-up table (ADKD sequences)', where: 'SIS ICD Annex C' },
  { topic: 'Start-up scenarios (cold / warm / hot)', where: 'Receiver Guidelines 4.1.1' },
  { topic: 'Time synchronisation requirement', where: 'Receiver Guidelines 2.1' },
  { topic: 'Public key verification (Merkle)', where: 'Receiver Guidelines 5.1' },
  { topic: 'Root-key signature verification', where: 'Receiver Guidelines 5.2' },
  { topic: 'TESLA key / tag verification', where: 'Receiver Guidelines 5.4 / 5.5' },
  { topic: 'Lifecycle events (EOC, CREV, NPK, …)', where: 'Receiver Guidelines 4.2' },
];
---
<BaseLayout
  title="Sources"
  description="The official Galileo OSNMA documents this site is built on."
>
  <PageHeader
    eyebrow="7 · Reference"
    title="Sources"
    lead="Everything on this site is drawn from two official Galileo OSNMA documents and the accompanying test vectors."
  />

  <Callout type="note" title="This is an independent explainer">
    <p>
      This website is an educational resource, not an official source. For any
      implementation work, always rely on the authoritative documents below,
      published by EUSPA and distributed via the European GNSS Service Centre (GSC)
      on its official OSNMA pages.
    </p>
  </Callout>

  <h2>The two authoritative documents</h2>

  <h3>Galileo OSNMA Signal-in-Space Interface Control Document (SIS ICD), Issue 1.1</h3>
  <p>
    The bit-level definition of the protocol. It specifies the message structures
    (NMA Header, DSM-KROOT, DSM-PKR and the MACK message), the field value tables,
    the mathematics of the TESLA key chain and the Merkle tree, and the
    cryptographic functions and parameters OSNMA uses. When this site cites
    <strong>SIS ICD §x</strong>, it refers to this document.
  </p>

  <h3>Galileo OSNMA Receiver Guidelines, Issue 1.3</h3>
  <p>
    The receiver's view of the protocol. It describes the start-up scenarios
    (cold, warm and hot start), the end-to-end verification chain, the time
    synchronisation requirement, the step-by-step key and tag verification
    algorithms, and how a receiver should react to lifecycle events such as chain
    and key renewal or revocation. When this site cites
    <strong>Rx Guidelines §x</strong>, it refers to this document.
  </p>

  <h2>The official test vectors</h2>
  <p>
    The Receiver Guidelines v1.3 ship with a set of official test vectors: real
    Merkle trees and public keys (in XML), real Digital Signature Messages, and
    raw Galileo I/NAV streams (CSV) covering nominal operation and every lifecycle
    event. This site's live <a href={withBase('/machinery/merkle-tree')}>Merkle tree demo</a>
    recomputes a root from one of these real public keys, so the numbers you see
    are the genuine published values rather than illustrations. The test vectors
    are an annex to the Receiver Guidelines v1.3 and are covered by the Terms of
    Use and disclaimers specified therein.
  </p>

  <h2>Where each topic is documented</h2>
  <p>Use this map to jump from a concept on this site to its clause in the official documents.</p>

  <figure class="my-5 overflow-hidden rounded-xl border border-line bg-panel/50">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr class="text-left text-xs uppercase tracking-wide text-muted">
            <th class="border-b border-line px-4 py-2 font-semibold">Topic</th>
            <th class="border-b border-line px-4 py-2 font-semibold">Documented in</th>
          </tr>
        </thead>
        <tbody>
          {
            topicMap.map((row) => (
              <tr class="border-b border-line/60 last:border-0 hover:bg-panel2/40">
                <td class="px-4 py-2 text-ink/90">{row.topic}</td>
                <td class="px-4 py-2 font-mono text-brand-bright">{row.where}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </figure>

  <Callout type="tip" title="Finding the documents">
    <p>
      Search the European GNSS Service Centre (GSC) website for "OSNMA" to reach
      the official OSNMA section, where the SIS ICD, the Receiver Guidelines and
      the test vectors are published for download.
    </p>
  </Callout>
</BaseLayout>
