---
/** Site footer with provenance. This site is an explainer; the authority is EUSPA. */
import { withBase } from '@/lib/withBase';
---
<footer class="mt-16 border-t border-line py-8 text-sm text-muted">
  <div class="space-y-2">
    <p>
      An independent educational explainer. The authoritative references are the
      <strong class="text-ink">Galileo OSNMA SIS ICD v1.1</strong> and the
      <strong class="text-ink">OSNMA Receiver Guidelines v1.3</strong>, published by the
      European Union Agency for the Space Programme (EUSPA) via the GSC.
    </p>
    <p>
      Always consult the official documents for implementation. See
      <a href={withBase('/reference/sources')} class="text-brand-bright underline underline-offset-2">Sources</a>.
    </p>
    <p>
      Part of <a href="https://iovis.space/" class="text-brand-bright underline underline-offset-2">iovis.space</a>.
    </p>
  </div>
</footer>
