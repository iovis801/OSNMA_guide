---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---
<header class="mb-8 border-b border-line pb-6">
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-brand">{eyebrow}</p>}
  <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
  {lead && <p class="mt-3 text-lg text-muted">{lead}</p>}
</header>
